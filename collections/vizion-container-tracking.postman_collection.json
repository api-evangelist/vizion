    {
      "id": "56075edc-350c-4f99-82f8-61755454159e",
      "name": "Updates",
      "description": {
        "content": "Retrieve tracking event updates for a reference",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "1750f292-8089-4b31-84a2-3097bbef49e0",
          "name": "List Reference Updates",
          "request": {
            "name": "List Reference Updates",
            "description": {
              "content": "Retrieve tracking event updates for a specific reference. This is the polling alternative to webhooks. Returns all tracking milestones and location events received for the container since subscription.",
              "type": "text/plain"
            },
            "url": {
